roduct (string), value = position (0 = no position, >0 = long, <0 = short)\n","    # represents current position in product\n","\n","  # state.own_trades dictionary: key = product (string), value = List of Trade objects\n","    # trade.price, trade.quantity, trade.timestamp to represent your trades from previous iteration\n","\n","  # state.market_trades dictionary: key = product (string), value = List of Trade objects\n","    # trade.price, trade.quantity, trade.timestamp to represent trades bebtween bots\n","\n","  # state.timestamp integer: current iteration number\n","\n","  # state.observations: additional market data (not too sure what this means)\n","\n","\n","############################################\n","from datamodel import Order, TradingState\n","\n","class EmeraldTrader:\n","  def take_obvious_trades(best_bid, bid_volume, best_ask, ask_volume, orders):\n","    if best_bid > 10000:\n","      orders.append(Order(\"EMERALDS\", best_bid, -bid_volume))\n","    if best_ask < 10000:\n","      orders.append(Order(\"EMERALDS\", best_ask, ask_volume))\n","\n","  def make_better_trades(best_bid, best_ask, size, orders):\n","    orders.append(Order(\"EMERALDS\", best_bid + 1, size))\n","    orders.append(Order(\"EMERALDS\", best_ask - 1, -size))\n","\n","\n","class TomatoTrader:\n","  def take_obvious_trades(best_bid, bid_volume, best_ask, ask_volume, mid_price, orders):\n","    if best_bid > mid_price:\n","      orders.append(Order(\"TOMATOES\", best_bid, -bid_volume))\n","    if best_ask < mid_price:\n","      orders.append(Order(\"TOMATOES\", best_ask, ask_volume))\n","\n","  def make_better_trades(best_bid, best_ask, size, orders):\n","    orders.append(Order(\"TOMATOES\", best_bid + 1, size))\n","    orders.append(Order(\"TOMATOES\", best_ask - 1, -size))\n","\n","\n","class Trader:\n","  def get_best_bid(self, order_depth):\n","    if not order_depth.buy_orders:\n","        return None, 0\n","    best_bid = max(order_depth.buy_orders.keys())\n","    return best_bid, order_depth.buy_orders[best_bid]\n","\n","  def get_best_ask(self, order_depth):\n","    if not order_depth.sell_orders:\n","        return None, 0\n","    best_ask = min(order_depth.sell_orders.keys())\n","    return best_ask, order_depth.sell_orders[best_ask]\n","\n","  def run(self, state):\n","    result = {}\n","    emerald_orders = []\n","    tomato_orders = []\n","\n","\n","    order_depth = state.order_depths.get(\"EMERALDS\")\n","    if order_depth:\n","      best_bid, bid_volume = self.get_best_bid(order_depth)\n","      best_ask, ask_volume = self.get_best_ask(order_depth)\n","      if best_bid is not None and best_ask is not None:\n","        EmeraldTrader.take_obvious_trades(best_bid, bid_volume, best_ask, ask_volume, emerald_orders)\n","        EmeraldTrader.make_better_trades(best_bid, best_ask, 5, emerald_orders)\n","        result[\"EMERALDS\"] = emerald_orders\n","\n","    order_depth = state.order_depths.get(\"TOMATOES\")\n","    if order_depth:\n","      best_bid, bid_volume = self.get_best_bid(order_depth)\n","      best_ask, ask_volume = self.get_best_ask(order_depth)\n","      if best_bid is not None and best_ask is not None:\n","        TomatoTrader.take_obvious_trades(best_bid, bid_volume, best_ask, ask_volume, (best_bid + best_ask) / 2, tomato_orders)\n","        TomatoTrader.make_better_trades(best_bid, best_ask, 5, tomato_orders)\n","        result[\"TOMATOES\"] = tomato_orders\n","\n","    return result, 0, \"\""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"2GGFefY003Ge","executionInfo":{"status":"ok","timestamp":1775968971668,"user_tz":240,"elapsed":20,"user":{"displayName":"Srivarun Kankanala","userId":"09168563988268045475"}},"outputId":"ffee7f4f-f78e-4934-e780-c4b3bc94a41b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting trader.py\n"]}]}]}